# Spring Configuration
SPRING_PROFILES_ACTIVE=dev

# Database Configuration
# For Docker Compose, use: postgres (service name)
# For local development, use: localhost
DB_HOST=localhost
DB_PORT=5432
DB_NAME=robin_gateway
DB_USER=robin
DB_PASSWORD=changeme
POSTGRES_PASSWORD=changeme

# JWT Configuration
# Generate with: openssl rand -base64 32
JWT_SECRET=change-this-to-a-very-long-and-secure-random-secret-key-minimum-64-characters

# Redis Configuration
# For Docker Compose, use: redis (service name)
# For local development, use: localhost
REDIS_HOST=localhost
REDIS_PORT=6379

# Robin MTA Backend URLs
# For Docker Compose, use: http://robin-mta:8090 and http://robin-mta:8080
# For local development, use: http://localhost:8090 and http://localhost:8080
ROBIN_MTA_CLIENT_API_URL=http://localhost:8090
ROBIN_MTA_SERVICE_API_URL=http://localhost:8080

# Application Configuration
SERVER_PORT=8080
ROBIN_CONFIG_PATH=cfg/

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_ROBIN=DEBUG

# AWS Configuration (Optional - for Route53 DNS management)
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here
# AWS_REGION=us-east-1

# Encryption Configuration
# Generate with: openssl rand -base64 32
# ENCRYPTION_SECRET_KEY=your_encryption_key_here

# OWASP Dependency Check - NVD API Key
# Get your free API key at: https://nvd.nist.gov/developers/request-an-api-key
# REQUIRED for running security scans with ./run-owasp-scan.sh
# NVD_API_KEY=your_nvd_api_key_here
