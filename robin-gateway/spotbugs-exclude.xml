<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!--
        SpotBugs exclusions for Robin Gateway
        Document all intentional @SuppressWarnings usage
    -->

    <!-- Lombok-generated code -->
    <Match>
        <Class name="~.*\$.*"/> <!-- Exclude inner classes generated by Lombok -->
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

    <!-- JPA Entities - Intentional public fields for ORM -->
    <Match>
        <Package name="~com\.robin\.gateway\.model\.entity.*"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

    <!-- DTOs - Intentional public fields for serialization -->
    <Match>
        <Package name="~com\.robin\.gateway\.model\.dto.*"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

    <!-- Spring Boot configuration classes -->
    <Match>
        <Class name="~.*Config$"/>
        <Bug pattern="UWF_FIELD_NOT_INITIALIZED_IN_CONSTRUCTOR"/>
    </Match>

    <!-- Test classes -->
    <Match>
        <Class name="~.*Test$"/>
        <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE"/>
    </Match>

    <!-- SecurityConfig.java - JWT claims are inherently untyped -->
    <Match>
        <Class name="com.robin.gateway.config.SecurityConfig"/>
        <Method name="lambda$securityWebFilterChain$0"/>
        <Bug pattern="BC_UNCONFIRMED_CAST"/>
    </Match>

    <!-- Reactive WebFlux - Flux/Mono null handling -->
    <Match>
        <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
        <Or>
            <Method name="~.*Mono.*"/>
            <Method name="~.*Flux.*"/>
        </Or>
    </Match>

    <!-- False positive: Spring manages these beans -->
    <Match>
        <Bug pattern="NP_NONNULL_FIELD_NOT_INITIALIZED_IN_CONSTRUCTOR"/>
        <Or>
            <Class name="~.*Controller$"/>
            <Class name="~.*Service$"/>
            <Class name="~.*Repository$"/>
        </Or>
    </Match>

    <!-- Serialization - Entities don't need serialVersionUID -->
    <Match>
        <Package name="~com\.robin\.gateway\.model\.entity.*"/>
        <Bug pattern="SE_NO_SERIALVERSIONID"/>
    </Match>

    <!-- Intentional empty catch blocks for cleanup operations -->
    <Match>
        <Class name="~.*Service$"/>
        <Method name="cleanup"/>
        <Bug pattern="DE_MIGHT_IGNORE"/>
    </Match>

</FindBugsFilter>
